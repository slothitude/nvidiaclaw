[gd_scene load_steps=2 format=3 uid="uid://dynamic_panel_embedded"]

[ext_resource type="Script" path="res://dynamic_panel.gd" id="1"]

[node name="DynamicPanel" type="Control"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1")

[node name="VBox" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="Header" type="HBoxContainer" parent="VBox"]
layout_mode = 2

[node name="Title" type="Label" parent="VBox/Header"]
layout_mode = 2
size_flags_horizontal = 3
text = "🎨 Dynamic UI Panel"
horizontal_alignment = 1

[node name="ButtonBar" type="HBoxContainer" parent="VBox"]
layout_mode = 2
theme_override_constants/separation = 5

[node name="MockBtn" type="Button" parent="VBox/ButtonBar"]
layout_mode = 2
size_flags_horizontal = 3
text = "🎭 Mock UI"

[node name="RequestBtn" type="Button" parent="VBox/ButtonBar"]
layout_mode = 2
size_flags_horizontal = 3
text = "🔄 Request AI"

[node name="ClearBtn" type="Button" parent="VBox/ButtonBar"]
layout_mode = 2
text = "🗑️"

[node name="DetachBtn" type="Button" parent="VBox/ButtonBar"]
layout_mode = 2
text = "📎 Detach"
tooltip_text = "Detach into a separate window"

[node name="HSeparator" type="HSeparator" parent="VBox"]
layout_mode = 2

[node name="ScrollContainer" type="ScrollContainer" parent="VBox"]
layout_mode = 2
size_flags_vertical = 3

[node name="PanelContainer" type="PanelContainer" parent="VBox/ScrollContainer"]
custom_minimum_size = Vector2(0, 300)
layout_mode = 2
size_flags_vertical = 3

[node name="HSeparator2" type="HSeparator" parent="VBox"]
layout_mode = 2

[node name="StatusBar" type="HBoxContainer" parent="VBox"]
layout_mode = 2

[node name="StatusLabel" type="Label" parent="VBox/StatusBar"]
layout_mode = 2
size_flags_horizontal = 3
text = "Ready"
horizontal_alignment = 1

[node name="StateBar" type="HBoxContainer" parent="VBox"]
layout_mode = 2

[node name="StateLabel" type="Label" parent="VBox/StateBar"]
layout_mode = 2
size_flags_horizontal = 3
text = "State: {}"
horizontal_alignment = 1
autowrap_mode = 2

[connection signal="pressed" from="VBox/ButtonBar/MockBtn" to="." method="_on_mock_btn_pressed"]
[connection signal="pressed" from="VBox/ButtonBar/RequestBtn" to="." method="_on_request_btn_pressed"]
[connection signal="pressed" from="VBox/ButtonBar/ClearBtn" to="." method="_on_clear_btn_pressed"]
[connection signal="pressed" from="VBox/ButtonBar/DetachBtn" to="." method="_on_detach_btn_pressed"]
